generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Transaction {
  id          String   @id @default(uuid())
  date        DateTime
  description String
  amount      Float
  type        String   @default("saida")
  isForecast  Boolean  @default(false)
  category    String
  groupId     String?
  createdAt   DateTime @default(now())
}

model Budget {
  id        String   @id @default(uuid())
  name      String
  amount    Float
  divideBy  Int      @default(30)
  createdAt DateTime @default(now())
}
